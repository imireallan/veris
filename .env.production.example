# Public routing
# Domain mode:
#   CADDY_SITE_ADDRESS=veris.example.com
#   SITE_URL=https://veris.example.com
# Staging/no-domain mode:
#   CADDY_SITE_ADDRESS=:80
#   SITE_URL=http://ec2-12-34-56-78.compute-1.amazonaws.com
CADDY_SITE_ADDRESS=:80
SITE_URL=http://ec2-12-34-56-78.compute-1.amazonaws.com
AI_PUBLIC_URL=http://ec2-12-34-56-78.compute-1.amazonaws.com/ai
TLS_EMAIL=ops@example.com

# Frontend session
SESSION_SECRET=CHANGE_THIS_SESSION_SECRET_VALUE
# For no-domain HTTP staging, keep frontend session cookies non-secure so the browser stores them.
# For real HTTPS domains, omit this or set it to True.
FRONTEND_SESSION_COOKIE_SECURE=False

# Django
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_DJANGO_VALUE
ALLOWED_HOSTS=ec2-12-34-56-78.compute-1.amazonaws.com,12.34.56.78
CORS_ALLOWED_ORIGINS=http://ec2-12-34-56-78.compute-1.amazonaws.com
CSRF_TRUSTED_ORIGINS=http://ec2-12-34-56-78.compute-1.amazonaws.com
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/veris
POSTGRES_DB=veris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# S3 media storage
USE_S3=true
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=veris-media-prod
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# Email via AWS SES SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME_SES_SMTP_USERNAME
EMAIL_HOST_PASSWORD=CHANGE_ME_SES_SMTP_PASSWORD
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=CHANGE_ME_VERIFIED_SES_SENDER_EMAIL
SERVER_EMAIL=CHANGE_ME_VERIFIED_SES_SENDER_EMAIL

# AI providers
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
PINECONE_API_KEY=CHANGE_ME_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=veris
HUGGINGFACE_API_KEY=CHANGE_ME_HUGGINGFACE_API_KEY
EMBEDDING_MODEL_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
