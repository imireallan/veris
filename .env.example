# ── App ───────────────────────────────────────────────────────
SESSION_SECRET=***
SITE_URL=http://localhost:3000

# ── Backend (Django) ─────────────────────────────────────────
DJANGO_SECRET_KEY=***
DATABASE_URL=postgresql://postgres:***@db:5432/veris
AI_ENGINE_URL=http://ai_engine:8001
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── AI Engine (FastAPI) ──────────────────────────────────────
OPENAI_API_KEY=***
PINECONE_API_KEY=***
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=sustainability-ai
GROQ_API_KEY=***

# ── Embedding Model (Choose: openai or huggingface) ───────────
# HuggingFace is free (rate-limited), OpenAI is paid (faster/reliable)
EMBEDDING_MODEL_PROVIDER=openai
# For huggingface: sentence-transformers/all-MiniLM-L6-v2
# For openai: text-embedding-3-small
EMBEDDING_MODEL_NAME=text-embedding-3-small
HUGGINGFACE_API_KEY=***

# ── File Storage (Local vs S3) ────────────────────────────────
# Development: USE_S3=false (stores in ./media/)
# Production: USE_S3=true (stores in AWS S3)
USE_S3=false
# AWS_ACCESS_KEY_ID=***
# AWS_SECRET_ACCESS_KEY=***
# AWS_STORAGE_BUCKET_NAME=veris-media-prod
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=  # Optional: CloudFront domain (e.g., d1234.cloudfront.net)

# ── Frontend ──────────────────────────────────────────────────
API_URL=http://localhost:8000
VITE_AI_API_URL=http://localhost:8001

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=veris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=***

# ── Email ─────────────────────────────────────────────────────
# Local dev: MailHog (SMTP on localhost:1025, Web UI on localhost:8025)
# Production: Configure real SMTP (SendGrid, AWS SES, etc.)
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=false
DEFAULT_FROM_EMAIL=no-reply@veris.local
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend  # default
