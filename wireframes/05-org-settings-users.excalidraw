    {
      "type": "text",
      "id": "t_main",
      "x": 300,
      "y": 150,
      "width": 840,
      "height": 520,
      "text": "Team Members\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ [+ Invite Member]  [Export CSV]                                    │\n└─────────────────────────────────────────────────────────────────────┘\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ Name              Email                    Role        Status       │\n├─────────────────────────────────────────────────────────────────────┤\n│ Allan Imire       allanimire@gmail.com     ADMIN       Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Sarah Chen        sarah@bettercoal.org     COORDINATOR Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ James Mwangi      james@bettercoal.org     OPERATOR    Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Emma Wilson       emma@tdi-global.com      CONSULTANT  Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Michael Brown     mike@bettercoal.org      ASSESSOR    Active       │\n│                   [Edit Role] [Deactivate]                          │\n└─────────────────────────────────────────────────────────────────────┘\n\nPENDING INVITATIONS (2)\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ Email                    Role        Sent          Status          │\n├─────────────────────────────────────────────────────────────────────┤\n│ lisa@bettercoal.org      COORDINATOR Apr 20       Pending [Resend] │\n│ david@bettercoal.org     OPERATOR    Apr 22       Pending [Resend] │\n└─────────────────────────────────────────────────────────────────────┘\n\nInvite expires in 30 days. Resend if expired.",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "main_content",
      "originalText": "Team Members\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ [+ Invite Member]  [Export CSV]                                    │\n└─────────────────────────────────────────────────────────────────────┘\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ Name              Email                    Role        Status       │\n├─────────────────────────────────────────────────────────────────────┤\n│ Allan Imire       allanimire@gmail.com     ADMIN       Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Sarah Chen        sarah@bettercoal.org     COORDINATOR Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ James Mwangi      james@bettercoal.org     OPERATOR    Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Emma Wilson       emma@tdi-global.com      CONSULTANT  Active       │\n│                   [Edit Role] [Deactivate]                          │\n├─────────────────────────────────────────────────────────────────────┤\n│ Michael Brown     mike@bettercoal.org      ASSESSOR    Active       │\n│                   [Edit Role] [Deactivate]                          │\n└─────────────────────────────────────────────────────────────────────┘\n\nPENDING INVITATIONS (2)\n\n┌─────────────────────────────────────────────────────────────────────┐\n│ Email                    Role        Sent          Status          │\n├─────────────────────────────────────────────────────────────────────┤\n│ lisa@bettercoal.org      COORDINATOR Apr 20       Pending [Resend] │\n│ david@bettercoal.org     OPERATOR    Apr 22       Pending [Resend] │\n└─────────────────────────────────────────────────────────────────────┘\n\nInvite expires in 30 days. Resend if expired.",
      "autoResize": true
