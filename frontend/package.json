{
  "name": "sustainability-ai-frontend",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "react-router build",
    "dev": "react-router dev",
    "dev:devtools": "ENABLE_ROUTER_DEVTOOLS=true react-router dev",
    "dev:no-devtools": "ENABLE_ROUTER_DEVTOOLS=false react-router dev",
    "start": "react-router-serve ./build/server/index.js",
    "typecheck": "react-router typegen && tsc",
    "test": "vitest",
    "test:ui": "vitest --ui --open",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "playwright": "TEST_MOCK=true playwright test",
    "playwright:ui": "TEST_MOCK=true playwright test --ui",
    "playwright:all": "playwright test",
    "playwright:ui:all": "playwright test --ui",
    "playwright:org-admin": "playwright test tests/e2e/org-admin-workflows.spec.ts --project=chromium",
    "playwright:ui:org-admin": "playwright test tests/e2e/org-admin-workflows.spec.ts --ui --project=chromium",
    "playwright:setup": "playwright test tests/e2e/auth.setup.ts --project=setup",
    "playwright:ui:setup": "playwright test tests/e2e/auth.setup.ts --ui --project=setup",
    "playwright:codegen": "playwright codegen localhost:5173",
    "test:e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@fontsource-variable/geist": "^5.2.8",
    "@react-router/node": "^7.12.0",
    "@react-router/serve": "^7.12.0",
    "@tiptap/extension-image": "^3.22.2",
    "@tiptap/extension-link": "^3.22.2",
    "@tiptap/react": "^3.22.2",
    "@tiptap/starter-kit": "^3.22.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.38.0",
    "isbot": "^5.1.31",
    "lucide-react": "^0.563.0",
    "motion": "^12.34.1",
    "next-themes": "^0.4.6",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router": "^7.12.0",
    "shadcn": "^4.2.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.1",
    "@react-router/dev": "^7.12.0",
    "@tailwindcss/vite": "^4.1.13",
    "@testing-library/jest-dom": "^6.5.0",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^2.1.9",
    "@vitest/ui": "^2.1.3",
    "happy-dom": "^15.7.3",
    "jsdom": "^25.0.1",
    "msw": "^2.4.11",
    "react-router-devtools": "^6.2.0",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.9.3",
    "vite": "^7.0.4",
    "vite-tsconfig-paths": "^5.1.4",
    "vitest": "^2.1.3"
  }
}
