# Veris Environment Variables
# Copy this file to .env and fill in your values

# ── Django Settings ────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.development
SECRET_KEY=your-secret-key-change-in-production

# ── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql://postgres:postgres@db:5432/veris

# ── Email Configuration (Local Development) ───────────────────
# Fake SMTP server - emails appear in web UI at http://localhost:1080
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
DEFAULT_FROM_EMAIL=no-reply@veris.local
SERVER_EMAIL=no-reply@veris.local

# ── Email Configuration (Production - Uncomments for real SMTP) ─
# Example: SendGrid
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=your-sendgrid-api-key
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com
# SERVER_EMAIL=noreply@yourdomain.com

# Example: AWS SES
# EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
# EMAIL_PORT=587
# EMAIL_HOST_USER=your-ses-smtp-user
# EMAIL_HOST_PASSWORD=your-ses-smtp-password
# EMAIL_USE_TLS=True
# DEFAULT_FROM_EMAIL=noreply@yourdomain.com

# ── CORS ──────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── AI / Embeddings ───────────────────────────────────────────
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_ENVIRONMENT=us-east1-gcp
PINECONE_INDEX_NAME=sustainability-ai
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key

# Choose: 'openai' or 'huggingface'
EMBEDDING_MODEL_PROVIDER=openai
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2

# ── File Storage ──────────────────────────────────────────────
USE_S3=False

# AWS S3 (only if USE_S3=True)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=
