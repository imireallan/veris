    },
    {
      "type": "text",
      "id": "t_rbac",
      "x": 60,
      "y": 715,
      "width": 530,
      "height": 115,
      "text": "ROLE PERMISSIONS MATRIX:\n\nADMIN       → Org settings, members, all assessments\nCOORDINATOR → Create assessments, manage sites, invite users\nCONSULTANT  → View-only advisory access (TDi delivery users)\nOPERATOR    → Site-level data entry only\nASSESSOR    → Review submissions, create findings, export reports\n\n⚠️ SUPERADMINs do NOT need OrganizationMembership\n   (Platform authority is global, not tenant-scoped)",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "rbac_matrix",
      "originalText": "ROLE PERMISSIONS MATRIX:\n\nADMIN       → Org settings, members, all assessments\nCOORDINATOR → Create assessments, manage sites, invite users\nCONSULTANT  → View-only advisory access (TDi delivery users)\nOPERATOR    → Site-level data entry only\nASSESSOR    → Review submissions, create findings, export reports\n\n⚠️ SUPERADMINs do NOT need OrganizationMembership\n   (Platform authority is global, not tenant-scoped)",
      "autoResize": true
    },
    {
      "type": "rectangle",
      "id": "invitation_flow",
      "x": 620,
      "y": 700,
      "width": 530,
      "height": 140,
      "roundness": { "type": 3 },
      "backgroundColor": "#b2f2bb",
      "fillStyle": "solid",
      "boundElements": [{ "id": "t_invite", "type": "text" }]
    },
    {
      "type": "text",
      "id": "t_invite",
      "x": 630,
      "y": 715,
      "width": 510,
      "height": 115,
      "text": "INVITATION FLOW:\n\n1. Admin invites → creates Invitation (email, role, org_id)\n2. Email sent with token link\n3. User clicks link:\n   • New user → Sign up flow → auto-attach membership\n   • Existing → login → auto-attach membership\n4. Token expires in 30 days\n5. Resend invalidates old token, creates new\n\nSee: veris-invitation-onboarding-pattern",
      "fontSize": 14,
      "fontFamily": 1,
      "strokeColor": "#1e1e1e",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "invitation_flow",
      "originalText": "INVITATION FLOW:\n\n1. Admin invites → creates Invitation (email, role, org_id)\n2. Email sent with token link\n3. User clicks link:\n   • New user → Sign up flow → auto-attach membership\n   • Existing → login → auto-attach membership\n4. Token expires in 30 days\n5. Resend invalidates old token, creates new\n\nSee: veris-invitation-onboarding-pattern",
      "autoResize": true
    },
