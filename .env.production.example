# ── App ───────────────────────────────────────────────────────
SESSION_SECRET=***
SITE_URL=https://your-domain.com
AI_PUBLIC_URL=https://your-domain.com/ai

# ── Backend (Django) ─────────────────────────────────────────
DJANGO_SECRET_KEY=***
DATABASE_URL=postgresql://postgres:***@db:5432/veris
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,backend,localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Security settings for HTTPS
SECURE_SSL_REDIRECT=True
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True

# ── AI Engine (FastAPI) ──────────────────────────────────────
OPENAI_API_KEY=***
PINECONE_API_KEY=***
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=sustainability-ai
GROQ_API_KEY=***

# ── Embedding Model (Choose: openai or huggingface) ───────────
EMBEDDING_MODEL_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
HUGGINGFACE_API_KEY=***

# ── File Storage (S3 for production) ─────────────────────────
USE_S3=true
AWS_ACCESS_KEY_ID=***
AWS_SECRET_ACCESS_KEY=***
AWS_STORAGE_BUCKET_NAME=veris-media-prod
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=  # Optional: CloudFront domain (e.g., d1234.cloudfront.net)

# ── Frontend ──────────────────────────────────────────────────
API_URL=http://backend:8000
VITE_API_URL=https://your-domain.com
VITE_AI_API_URL=https://your-domain.com/ai
VITE_SITE_URL=https://your-domain.com

# ── Database ──────────────────────────────────────────────────
POSTGRES_DB=veris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=***

# ── Email (AWS SES for production) ────────────────────────────
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=***
EMAIL_HOST_PASSWORD=***
EMAIL_USE_TLS=True
DEFAULT_FROM_EMAIL=no-reply@your-domain.com
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend

# ── Caddy / TLS ───────────────────────────────────────────────
TLS_EMAIL=admin@your-domain.com
CADDY_SITE_ADDRESS=your-domain.com
