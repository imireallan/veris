# No-domain staging template for Veris on EC2 public DNS/IP
# Replace these placeholders after terraform apply:
# - __APP_PUBLIC_DNS__ from Terraform output app_public_dns
# - __APP_PUBLIC_IP__ from Terraform output app_public_ip
# - __S3_BUCKET_NAME__ with the same bucket name used in terraform.tfvars
#
# This template uses plain HTTP + AWS SES SMTP with a verified email identity.
# If SES is still sandboxed, recipients must also be verified in SES.

# Public routing
CADDY_SITE_ADDRESS=:80
SITE_URL=http://__APP_PUBLIC_DNS__
AI_PUBLIC_URL=http://__APP_PUBLIC_DNS__/ai
TLS_EMAIL=ops@example.com

# Frontend session
SESSION_SECRET=CHANGE_ME_LONG_RANDOM_SESSION_VALUE

# Django
DJANGO_SECRET_KEY=CHANGE_ME_LONG_RANDOM_DJANGO_VALUE
ALLOWED_HOSTS=__APP_PUBLIC_DNS__,__APP_PUBLIC_IP__
CORS_ALLOWED_ORIGINS=http://__APP_PUBLIC_DNS__
CSRF_TRUSTED_ORIGINS=http://__APP_PUBLIC_DNS__
SECURE_SSL_REDIRECT=False
SESSION_COOKIE_SECURE=False
CSRF_COOKIE_SECURE=False
DJANGO_SETTINGS_MODULE=config.settings.production

# Database
DATABASE_URL=postgresql://postgres:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/veris
POSTGRES_DB=veris
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD

# S3 media storage
USE_S3=true
AWS_ACCESS_KEY_ID=CHANGE_ME_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=CHANGE_ME_AWS_SECRET_ACCESS_KEY
AWS_STORAGE_BUCKET_NAME=__S3_BUCKET_NAME__
AWS_S3_REGION_NAME=us-east-1
AWS_S3_CUSTOM_DOMAIN=

# Email via AWS SES SMTP
EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
EMAIL_HOST=email-smtp.us-east-1.amazonaws.com
EMAIL_PORT=587
EMAIL_HOST_USER=CHANGE_ME_SES_SMTP_USERNAME
EMAIL_HOST_PASSWORD=CHANGE_ME_SES_SMTP_PASSWORD
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
DEFAULT_FROM_EMAIL=CHANGE_ME_VERIFIED_SES_SENDER_EMAIL
SERVER_EMAIL=CHANGE_ME_VERIFIED_SES_SENDER_EMAIL

# AI providers
OPENAI_API_KEY=CHANGE_ME_OPENAI_API_KEY
PINECONE_API_KEY=CHANGE_ME_PINECONE_API_KEY
PINECONE_ENVIRONMENT=us-east-1
PINECONE_INDEX_NAME=veris
HUGGINGFACE_API_KEY=CHANGE_ME_HUGGINGFACE_API_KEY
EMBEDDING_MODEL_PROVIDER=openai
EMBEDDING_MODEL_NAME=text-embedding-3-small
