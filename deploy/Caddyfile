{
    email {$TLS_EMAIL}
}

{$CADDY_SITE_ADDRESS} {
    encode zstd gzip

    handle_path /static/* {
        root * /srv/static
        file_server
    }

    handle_path /media/* {
        root * /srv/media
        file_server
    }

    handle /api/* {
        reverse_proxy backend:8000
    }

    handle /ai/* {
        uri strip_prefix /ai
        reverse_proxy ai_engine:8001
    }

    handle {
        reverse_proxy frontend:3000
    }
}
